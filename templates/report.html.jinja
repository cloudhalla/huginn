<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Huginn — {{ report.target_hostname }}</title>
  <style>{{ css }}</style>
</head>
<body>
<div class="app">

  <!-- ── Sidebar ──────────────────────────────────────────────── -->
  <nav class="sidebar">
    <div class="sidebar-brand">
      <h1>huginn</h1>
      <p>Security Assessment Report</p>
    </div>
    <ul class="nav-list">
      <li>
        <a href="#summary">
          Executive Summary
          <span class="sidebar-count sc-default">{{ report.summary.total_failed }}</span>
        </a>
      </li>
      <li>
        <a href="#findings">
          Findings
          {% if report.summary.critical > 0 %}
          <span class="sidebar-count sc-critical">{{ report.summary.critical }}C</span>
          {% endif %}
          {% if report.summary.high > 0 %}
          <span class="sidebar-count sc-high">{{ report.summary.high }}H</span>
          {% endif %}
        </a>
      </li>
      <li>
        <a href="#audit">
          Controls Audit
          <span class="sidebar-count sc-default">{{ report.findings | length }}</span>
        </a>
      </li>
      <li><a href="#system">System Info</a></li>
      <li><a href="#users">Users &amp; Groups</a></li>
      <li><a href="#network">Network</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#software">Software</a></li>
    </ul>

    <div class="theme-toggle-wrap">
      <button id="theme-toggle" class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <span>Dark Mode</span>
        <span class="theme-toggle-icon">☽</span>
      </button>
    </div>

    <div class="sidebar-footer">
      <p>huginn v{{ report.version }} &bull; {{ report.generated_at_display }}</p>
    </div>
  </nav>

  <!-- ── Main content ─────────────────────────────────────────── -->
  <main class="main">

    <!-- Page header -->
    <header class="page-header">
      <div>
        <h1>{{ report.target_hostname }}</h1>
        <p class="subtitle">{{ report.target_os }} &bull; Assessed {{ report.generated_at_display }}</p>
      </div>
      <a href="#findings" class="risk-badge risk-{{ risk_level }}" title="Click to jump to findings">
        <span class="risk-num">{{ report.summary.risk_score }}</span>
        <span class="risk-label">Risk Score</span>
      </a>
    </header>

    <!-- ── Executive Summary ─────────────────────────────────── -->
    <section id="summary" class="section">
      <h2 class="section-title">Executive Summary</h2>
      <div class="summary-cards">
        <a class="summary-card card-critical clickable" href="#findings"
           data-filter="critical" title="Show critical findings">
          <span class="count">{{ report.summary.critical }}</span>
          <span class="label">Critical</span>
        </a>
        <a class="summary-card card-high clickable" href="#findings"
           data-filter="high" title="Show high findings">
          <span class="count">{{ report.summary.high }}</span>
          <span class="label">High</span>
        </a>
        <a class="summary-card card-medium clickable" href="#findings"
           data-filter="medium" title="Show medium findings">
          <span class="count">{{ report.summary.medium }}</span>
          <span class="label">Medium</span>
        </a>
        <a class="summary-card card-low clickable" href="#findings"
           data-filter="low" title="Show low findings">
          <span class="count">{{ report.summary.low }}</span>
          <span class="label">Low</span>
        </a>
        <a class="summary-card card-info clickable" href="#findings"
           data-filter="info" title="Show informational findings">
          <span class="count">{{ report.summary.info }}</span>
          <span class="label">Info</span>
        </a>
        <a class="summary-card card-pass clickable" href="#audit"
           title="View controls audit">
          <span class="count">{{ report.summary.passed }}</span>
          <span class="label">Passed</span>
        </a>
        <a class="summary-card card-skip clickable" href="#audit"
           title="View skipped controls">
          <span class="count">{{ report.summary.skipped }}</span>
          <span class="label">Skipped</span>
        </a>
      </div>
    </section>

    <!-- ── Findings ──────────────────────────────────────────── -->
    <section id="findings" class="section">
      <h2 class="section-title">Findings</h2>
      <div class="filter-bar">
        <button class="filter-btn active" data-severity="critical">Critical</button>
        <button class="filter-btn active" data-severity="high">High</button>
        <button class="filter-btn active" data-severity="medium">Medium</button>
        <button class="filter-btn active" data-severity="low">Low</button>
        <button class="filter-btn active" data-severity="info">Info</button>
      </div>

      <!-- Findings table — click a row to jump to its detail card -->
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th data-sort="severity" class="sortable">Severity ▼</th>
              <th data-sort="category" class="sortable">Category</th>
              <th data-sort="rule_id" class="sortable">Rule ID</th>
              <th data-sort="title" class="sortable">Title</th>
              <th style="width:32px"></th>
            </tr>
          </thead>
          <tbody id="findings-tbody">
            {% for f in report.findings %}
            {% if not f.passed and not f.skipped %}
            <tr class="finding-row"
                data-severity="{{ f.severity }}"
                data-category="{{ f.category }}"
                data-rule_id="{{ f.rule_id }}"
                data-title="{{ f.title }}"
                data-card="{{ f.id }}"
                title="Click to view finding details">
              <td><span class="badge badge-{{ f.severity }}">{{ f.severity_label }}</span></td>
              <td>{{ f.category_label }}</td>
              <td class="mono">{{ f.rule_id }}</td>
              <td>{{ f.title }}</td>
              <td><span class="row-link-hint">↓</span></td>
            </tr>
            {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>

      <!-- Findings detail accordion -->
      <h3 class="subsection-title" style="margin-top:28px;">Finding Details</h3>
      <div class="findings-detail">
        {% for f in report.findings %}
        {% if not f.passed and not f.skipped %}
        <div class="finding-card sev-{{ f.severity }}"
             id="card-{{ f.id }}"
             data-severity="{{ f.severity }}">
          <div class="finding-header">
            <div class="finding-header-left">
              <span class="badge badge-{{ f.severity }}">{{ f.severity_label }}</span>
              <span class="finding-title-text">{{ f.title }}</span>
            </div>
            <div class="finding-header-right">
              <span class="finding-rule-id">{{ f.rule_id }}</span>
              <span class="chevron">▼</span>
            </div>
          </div>
          <div class="finding-body">
            <div class="values-grid">
              <div class="value-item">
                <label>Current Value</label>
                <code>{{ f.current_value }}</code>
              </div>
              <div class="value-item">
                <label>Expected Value</label>
                <code>{{ f.expected_value }}</code>
              </div>
            </div>
            <div class="finding-section">
              <h4>Description</h4>
              <p>{{ f.description }}</p>
            </div>
            <div class="finding-section">
              <h4>Recommendation</h4>
              <p>{{ f.recommendation }}</p>
            </div>
            {% if f.references %}
            <div class="finding-section">
              <h4>Compliance References</h4>
              <div class="ref-tags">
                {% for ref in f.references %}
                <span class="ref-tag ref-{{ ref.framework | lower }}">{{ ref.framework }}: {{ ref.id }}</span>
                {% endfor %}
              </div>
            </div>
            {% endif %}
            {% if f.evidence %}
            <div class="finding-section">
              <h4>Evidence</h4>
              <pre class="evidence-block">{{ f.evidence }}</pre>
            </div>
            {% endif %}
          </div>
        </div>
        {% endif %}
        {% endfor %}
      </div>
    </section>

    <!-- ── Controls Audit ────────────────────────────────────── -->
    <section id="audit" class="section">
      <h2 class="section-title">Controls Audit</h2>
      <p class="section-desc">All security controls evaluated during this assessment. Failed controls appear in the Findings section above.</p>
      <div class="table-wrap">
        <table class="data-table audit-table">
          <thead>
            <tr>
              <th style="width:130px">Rule ID</th>
              <th style="width:76px">Platform</th>
              <th>Control</th>
              <th style="width:90px">Status</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {% for f in report.findings %}
            <tr class="audit-row audit-{{ "pass" if f.passed else ("skip" if f.skipped else "fail") }}">
              <td class="mono">{{ f.rule_id }}</td>
              <td>
                {% if f.os_target == "linux" %}
                <span class="os-badge os-linux">Linux</span>
                {% elif f.os_target == "windows" %}
                <span class="os-badge os-windows">Windows</span>
                {% else %}
                <span class="os-badge os-any">Any</span>
                {% endif %}
              </td>
              <td>{{ f.title }}</td>
              <td>
                {% if f.passed %}
                <span class="audit-badge audit-pass">PASS</span>
                {% elif f.skipped %}
                <span class="audit-badge audit-skip">SKIP</span>
                {% else %}
                <span class="audit-badge audit-fail">FAIL</span>
                {% endif %}
              </td>
              <td class="audit-notes">
                {% if f.passed %}
                Control satisfied — no action required.
                {% elif f.skipped %}
                {{ f.description }}
                {% else %}
                <span class="badge badge-{{ f.severity }}">{{ f.severity_label }}</span>
                <span class="audit-current-val">{{ f.current_value }}</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── System Info ────────────────────────────────────────── -->
    <section id="system" class="section">
      <h2 class="section-title">System Information</h2>
      <div class="info-grid">
        <div class="info-item">
          <label>Hostname</label>
          <span>{{ report.system_info.os.hostname | default("Unknown") }}</span>
        </div>
        <div class="info-item">
          <label>Operating System</label>
          <span>{{ report.system_info.os.name | default("Unknown") }}</span>
        </div>
        <div class="info-item">
          <label>Version</label>
          <span>{{ report.system_info.os.version | default("N/A") }}</span>
        </div>
        {% if report.system_info.os.build %}
        <div class="info-item">
          <label>Build</label>
          <span>{{ report.system_info.os.build }}</span>
        </div>
        {% endif %}
        <div class="info-item">
          <label>Architecture</label>
          <span>{{ report.system_info.os.architecture | default("Unknown") }}</span>
        </div>
        {% if report.system_info.os.domain %}
        <div class="info-item">
          <label>Domain</label>
          <span>{{ report.system_info.os.domain }}</span>
        </div>
        {% endif %}
        <div class="info-item">
          <label>Uptime</label>
          <span>{{ report.system_info.os.uptime_seconds // 3600 }}h {{ (report.system_info.os.uptime_seconds % 3600) // 60 }}m</span>
        </div>
        <div class="info-item">
          <label>Collected At</label>
          <span>{{ report.generated_at_display }}</span>
        </div>
      </div>
    </section>

    <!-- ── Users & Groups ─────────────────────────────────────── -->
    <section id="users" class="section">
      <h2 class="section-title">Users &amp; Groups</h2>

      <h3 class="subsection-title">Administrator Group Members</h3>
      <div class="tag-list">
        {% for member in report.system_info.users.admin_group_members %}
        <span class="user-tag admin-tag">{{ member }}</span>
        {% else %}
        <span class="empty-state">No members found (try running with elevated privileges)</span>
        {% endfor %}
      </div>

      <h3 class="subsection-title">Password Policy</h3>
      <div class="table-wrap">
        <table class="data-table">
          <tbody>
            <tr>
              <td>Minimum Length</td>
              <td>{% if report.system_info.users.password_policy.min_length %}{{ report.system_info.users.password_policy.min_length }} characters{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Maximum Age</td>
              <td>{% if report.system_info.users.password_policy.max_age_days %}{{ report.system_info.users.password_policy.max_age_days }} days{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Minimum Age</td>
              <td>{% if report.system_info.users.password_policy.min_age_days %}{{ report.system_info.users.password_policy.min_age_days }} days{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Password History</td>
              <td>{% if report.system_info.users.password_policy.history_count %}{{ report.system_info.users.password_policy.history_count }} passwords{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Complexity Required</td>
              <td>{% if report.system_info.users.password_policy.complexity_required is defined %}{% if report.system_info.users.password_policy.complexity_required %}<span class="badge badge-pass">Yes</span>{% else %}<span class="badge badge-high">No</span>{% endif %}{% else %}Not configured{% endif %}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="subsection-title">Lockout Policy</h3>
      <div class="table-wrap">
        <table class="data-table">
          <tbody>
            <tr>
              <td>Lockout Threshold</td>
              <td>{% if report.system_info.users.lockout_policy.threshold %}{{ report.system_info.users.lockout_policy.threshold }} invalid attempts{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Lockout Duration</td>
              <td>{% if report.system_info.users.lockout_policy.duration_minutes %}{{ report.system_info.users.lockout_policy.duration_minutes }} minutes{% else %}Not configured{% endif %}</td>
            </tr>
            <tr>
              <td>Observation Window</td>
              <td>{% if report.system_info.users.lockout_policy.observation_window_minutes %}{{ report.system_info.users.lockout_policy.observation_window_minutes }} minutes{% else %}Not configured{% endif %}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="subsection-title">Local Users ({{ report.system_info.users.users | length }})</h3>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Username</th>
              <th>UID</th>
              <th>Enabled</th>
              <th>Admin</th>
              <th>Password Expires</th>
            </tr>
          </thead>
          <tbody>
            {% for user in report.system_info.users.users %}
            <tr>
              <td>{{ user.username }}</td>
              <td>{{ user.uid | default("N/A") }}</td>
              <td>{% if user.enabled %}<span class="badge badge-pass">Yes</span>{% else %}<span class="badge badge-info">No</span>{% endif %}</td>
              <td>{% if user.is_admin %}<span class="badge badge-high">Admin</span>{% else %}No{% endif %}</td>
              <td>{{ "Yes" if user.password_expires else "No" }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="empty-state">No users found (insufficient privileges?)</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── Network ────────────────────────────────────────────── -->
    <section id="network" class="section">
      <h2 class="section-title">Network</h2>

      <h3 class="subsection-title">Firewall Status</h3>
      {% for profile in report.system_info.network.firewall_profiles %}
      <div class="fw-row">
        <strong>{{ profile.name }}</strong>
        {% if profile.enabled %}
        <span class="badge badge-pass">ENABLED</span>
        {% else %}
        <span class="badge badge-critical">DISABLED</span>
        {% endif %}
        <span class="fw-details">Inbound: {{ profile.inbound_default }} | Outbound: {{ profile.outbound_default }}</span>
      </div>
      {% else %}
      <p class="empty-state">No firewall data available (try running with elevated privileges)</p>
      {% endfor %}

      <h3 class="subsection-title">Network Interfaces ({{ report.system_info.network.interfaces | length }})</h3>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>IP Addresses</th>
              <th>MAC Address</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for iface in report.system_info.network.interfaces %}
            <tr>
              <td>{{ iface.name }}</td>
              <td>{{ iface.ip_addresses | join(", ") | default("N/A") }}</td>
              <td class="mono">{{ iface.mac_address | default("N/A") }}</td>
              <td>{% if iface.is_up %}<span class="badge badge-pass">UP</span>{% else %}<span class="badge badge-info">DOWN</span>{% endif %}</td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="empty-state">No interface data available</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if report.system_info.network.open_ports %}
      <h3 class="subsection-title">Listening Ports ({{ report.system_info.network.open_ports | length }})</h3>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Protocol</th>
              <th>Address</th>
              <th>Port</th>
              <th>State</th>
              <th>Process</th>
            </tr>
          </thead>
          <tbody>
            {% for port in report.system_info.network.open_ports %}
            <tr>
              <td>{{ port.protocol }}</td>
              <td class="mono">{{ port.local_addr }}</td>
              <td>{{ port.local_port }}</td>
              <td>{{ port.state }}</td>
              <td>{{ port.process_name | default("N/A") }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}

      <!-- DNS — rich resolvectl display if available, fallback to simple list -->
      {% if report.system_info.network.dns_info %}
      {% set dns = report.system_info.network.dns_info %}
      <h3 class="subsection-title">DNS Configuration</h3>
      <div class="dns-block">
        <div class="dns-section-header">Global</div>
        <div class="dns-table">
          {% if dns.protocols %}
          <div class="dns-row"><span class="dns-key">Protocols</span><span class="dns-val mono">{{ dns.protocols }}</span></div>
          {% endif %}
          {% if dns.resolv_conf_mode %}
          <div class="dns-row"><span class="dns-key">resolv.conf mode</span><span class="dns-val">{{ dns.resolv_conf_mode }}</span></div>
          {% endif %}
          {% if dns.current_dns_server %}
          <div class="dns-row"><span class="dns-key">Current DNS Server</span><span class="dns-val mono">{{ dns.current_dns_server }}</span></div>
          {% endif %}
          {% if dns.dns_servers %}
          <div class="dns-row"><span class="dns-key">DNS Servers</span><span class="dns-val mono">{{ dns.dns_servers | join(", ") }}</span></div>
          {% endif %}
          {% if dns.dns_domain %}
          <div class="dns-row"><span class="dns-key">DNS Domain</span><span class="dns-val mono">{{ dns.dns_domain }}</span></div>
          {% endif %}
        </div>
        {% for link in dns.links %}
        <div class="dns-section-header">Link {{ link.index }} ({{ link.name }})</div>
        <div class="dns-table">
          {% if link.current_scopes %}
          <div class="dns-row"><span class="dns-key">Current Scopes</span><span class="dns-val">{{ link.current_scopes }}</span></div>
          {% endif %}
          {% if link.protocols %}
          <div class="dns-row"><span class="dns-key">Protocols</span><span class="dns-val mono">{{ link.protocols }}</span></div>
          {% endif %}
          {% if link.current_dns_server %}
          <div class="dns-row"><span class="dns-key">Current DNS Server</span><span class="dns-val mono">{{ link.current_dns_server }}</span></div>
          {% endif %}
          {% if link.dns_servers %}
          <div class="dns-row"><span class="dns-key">DNS Servers</span><span class="dns-val mono">{{ link.dns_servers | join(", ") }}</span></div>
          {% endif %}
          {% if link.dns_domain %}
          <div class="dns-row"><span class="dns-key">DNS Domain</span><span class="dns-val mono">{{ link.dns_domain }}</span></div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% elif report.system_info.network.dns_servers %}
      <h3 class="subsection-title">DNS Servers</h3>
      <div class="tag-list">
        {% for dns in report.system_info.network.dns_servers %}
        <span class="user-tag">{{ dns }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </section>

    <!-- ── Services ──────────────────────────────────────────── -->
    <section id="services" class="section">
      <h2 class="section-title">Services</h2>

      <div class="section-toolbar">
        <span class="hint-text">{{ report.system_info.services.services | length }} services enumerated</span>
        <input type="search" id="svc-search" class="search-input" placeholder="Filter services…" oninput="filterServices(this.value)">
      </div>

      <div class="table-wrap">
        <table class="data-table" id="svc-table">
          <thead>
            <tr>
              <th>Service Name</th>
              <th>State</th>
              <th>Start Type</th>
              <th>Issues</th>
              <th>Binary Path</th>
            </tr>
          </thead>
          <tbody>
            {% for svc in report.system_info.services.services %}
            <tr class="svc-row{% if svc.unquoted_path or svc.weak_permissions %} svc-flagged{% endif %}">
              <td>
                <span class="svc-display-name">{{ svc.display_name }}</span>
                {% if svc.name != svc.display_name %}
                <span class="svc-internal-name mono">{{ svc.name }}</span>
                {% endif %}
              </td>
              <td>
                {% if svc.state == "running" %}
                <span class="badge badge-pass">Running</span>
                {% elif svc.state == "stopped" %}
                <span class="badge badge-info">Stopped</span>
                {% else %}
                <span class="badge badge-low">{{ svc.state }}</span>
                {% endif %}
              </td>
              <td>{{ svc.start_type }}</td>
              <td>
                {% if svc.unquoted_path %}
                <span class="badge badge-medium">Unquoted Path</span>
                {% endif %}
                {% if svc.weak_permissions %}
                <span class="badge badge-high">Weak Perms</span>
                {% endif %}
                {% if not svc.unquoted_path and not svc.weak_permissions %}
                <span class="badge badge-pass">OK</span>
                {% endif %}
              </td>
              <td class="mono svc-path">{{ svc.binary_path | default("N/A") }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="empty-state">No service data available (try running with elevated privileges)</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── Software ──────────────────────────────────────────── -->
    <section id="software" class="section">
      <h2 class="section-title">Software &amp; Security Tools</h2>

      <h3 class="subsection-title">AV / EDR Products</h3>
      <div class="tag-list">
        {% for av in report.system_info.software.av_edr_products %}
        <span class="user-tag av-tag">{{ av }}</span>
        {% else %}
        <span class="badge badge-critical">No AV/EDR products detected</span>
        {% endfor %}
      </div>

      {% if report.system_info.software.installed_software %}
      <h3 class="subsection-title">Installed Software ({{ report.system_info.software.installed_software | length }} packages)</h3>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Version</th>
              <th>Vendor</th>
            </tr>
          </thead>
          <tbody>
            {% for sw in report.system_info.software.installed_software %}
            <tr>
              <td>{{ sw.name }}</td>
              <td>{{ sw.version | default("N/A") }}</td>
              <td>{{ sw.vendor | default("N/A") }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
    </section>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <footer class="page-footer">
      <p>Generated by <strong>huginn</strong> v{{ report.version }} on {{ report.generated_at_display }}</p>
      <p>This report is confidential and intended for authorized personnel only.</p>
    </footer>

  </main>
</div>
<script>{{ js }}</script>
</body>
</html>
